# Copy to /opt/jams/.env and adjust values
# systemd service loads this via EnvironmentFile=

HOST=127.0.0.1
PORT=8000

# Comma-separated origins (only needed if frontend is on another domain)
CORS_ORIGINS=https://your-domain.com,http://your-domain.com

OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=qwen2.5:1.5b

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Optional: Hugging Face token for faster embedding model download
# HF_TOKEN=
